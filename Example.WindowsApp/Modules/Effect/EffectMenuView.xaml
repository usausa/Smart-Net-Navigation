<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:s="http://smart/windows"
             xmlns:views="clr-namespace:Example.WindowsApp.Views"
             xmlns:effect="clr-namespace:Example.WindowsApp.Modules.Effect"
             mc:Ignorable="d"
             x:Class="Example.WindowsApp.Modules.Effect.EffectMenuView"
             s:DataContextResolver.Type="{x:Type effect:EffectMenuViewModel}"
             d:DataContext="{d:DesignInstance Type={x:Type effect:EffectMenuViewModel}}"
             d:DesignWidth="480"
             d:DesignHeight="320"
             views:ShellProperty.Title="Effect Menu">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical"
                    Margin="10">
            <TextBlock Margin="0,0,0,8"
                       Text="Choose Animation"
                       FontWeight="Bold" />
            <Button Width="200"
                    Margin="0,4"
                    HorizontalAlignment="Left"
                    Command="{Binding Navigate}"
                    CommandParameter="Forward"
                    Content="Forward (Slide L/R Pair)" />
            <Button Width="200"
                    Margin="0,4"
                    HorizontalAlignment="Left"
                    Command="{Binding Navigate}"
                    CommandParameter="Back"
                    Content="Back (Slide R/L Pair)" />
            <Button Width="200"
                    Margin="0,4"
                    HorizontalAlignment="Left"
                    Command="{Binding Navigate}"
                    CommandParameter="Push"
                    Content="Push (Slide Up)" />
            <Button Width="200"
                    Margin="0,4"
                    HorizontalAlignment="Left"
                    Command="{Binding Navigate}"
                    CommandParameter="Pop"
                    Content="Pop (Slide Down)" />
            <Button Width="200"
                    Margin="0,4"
                    HorizontalAlignment="Left"
                    Command="{Binding Navigate}"
                    CommandParameter="Fade"
                    Content="Fade" />
            <Button Width="200"
                    Margin="0,4"
                    HorizontalAlignment="Left"
                    Command="{Binding Navigate}"
                    CommandParameter="Dialog"
                    Content="Dialog (Scale + Fade from Center)" />
            <Button Width="200"
                    Margin="0,4"
                    HorizontalAlignment="Left"
                    Command="{Binding Navigate}"
                    CommandParameter="Zoom"
                    Content="Zoom (Overshoot + Fade)" />
            <Button Width="200"
                    Margin="0,4"
                    HorizontalAlignment="Left"
                    Command="{Binding Navigate}"
                    CommandParameter="Drop"
                    Content="Drop (Bounce from Top)" />
            <Button Width="200"
                    Margin="0,4"
                    HorizontalAlignment="Left"
                    Command="{Binding Navigate}"
                    CommandParameter="Flip"
                    Content="Flip (Horizontal)" />
            <Button Width="200"
                    Margin="0,4"
                    HorizontalAlignment="Left"
                    Command="{Binding Navigate}"
                    CommandParameter="Rotate"
                    Content="Rotate (Spin + Fade)" />
            <Button Width="200"
                    Margin="0,4"
                    HorizontalAlignment="Left"
                    Command="{Binding Navigate}"
                    CommandParameter=""
                    Content="No Animation" />
        </StackPanel>
    </ScrollViewer>

</UserControl>
