<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:s="http://smart/windows"
             xmlns:views="clr-namespace:Example.WindowsApp.Views"
             xmlns:effect="clr-namespace:Example.WindowsApp.Modules.Effect"
             mc:Ignorable="d"
             x:Class="Example.WindowsApp.Modules.Effect.EffectMenuView"
             s:DataContextResolver.Type="{x:Type effect:EffectMenuViewModel}"
             d:DataContext="{d:DesignInstance Type={x:Type effect:EffectMenuViewModel}}"
             d:DesignWidth="480"
             d:DesignHeight="320"
             views:ShellProperty.Title="Effect Menu">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Section: Choose Animation -->
        <TextBlock Grid.Row="0"
                   Margin="0,0,0,6"
                   Text="Choose Animation"
                   FontWeight="Bold" />

        <UniformGrid Grid.Row="1"
                     VerticalAlignment="Top"
                     Columns="3">
            <Button Margin="3"
                    Command="{Binding Navigate}"
                    CommandParameter="Forward"
                    Content="Forward" />
            <Button Margin="3"
                    Command="{Binding Navigate}"
                    CommandParameter="Back"
                    Content="Back" />
            <Button Margin="3"
                    Command="{Binding Navigate}"
                    CommandParameter="Push"
                    Content="Push" />
            <Button Margin="3"
                    Command="{Binding Navigate}"
                    CommandParameter="Pop"
                    Content="Pop" />
            <Button Margin="3"
                    Command="{Binding Navigate}"
                    CommandParameter="Fade"
                    Content="Fade" />
            <Button Margin="3"
                    Command="{Binding Navigate}"
                    CommandParameter="Zoom"
                    Content="Zoom" />
            <Button Margin="3"
                    Command="{Binding Navigate}"
                    CommandParameter="Drop"
                    Content="Drop" />
            <Button Margin="3"
                    Command="{Binding Navigate}"
                    CommandParameter="Flip"
                    Content="Flip" />
            <Button Margin="3"
                    Command="{Binding Navigate}"
                    CommandParameter="Rotate"
                    Content="Rotate" />
            <Button Margin="3"
                    Command="{Binding Navigate}"
                    CommandParameter=""
                    Content="No Animation" />
        </UniformGrid>

        <!-- Separator -->
        <Separator Grid.Row="2"
                   Margin="0,8" />

        <!-- Section: Plugin Auto-Effect -->
        <StackPanel Grid.Row="3"
                    Orientation="Vertical">
            <TextBlock Margin="0,0,0,6"
                       Text="Plugin Auto-Effect Demo"
                       FontWeight="Bold" />
            <Button MinWidth="160"
                    Margin="3"
                    HorizontalAlignment="Left"
                    Command="{Binding NavigateDialog}"
                    Content="Dialog (Auto by Plugin)" />
        </StackPanel>
    </Grid>

</UserControl>
