<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:s="http://smart/windows"
             xmlns:views="clr-namespace:Example.WindowsApp.Views"
             xmlns:effect="clr-namespace:Example.WindowsApp.Modules.Effect"
             mc:Ignorable="d"
             x:Class="Example.WindowsApp.Modules.Effect.EffectDemoView"
             s:DataContextResolver.Type="{x:Type effect:EffectDemoViewModel}"
             d:DataContext="{d:DesignInstance Type={x:Type effect:EffectDemoViewModel}}"
             d:DesignWidth="480"
             d:DesignHeight="320"
             Background="#FFF0F8FF"
             views:ShellProperty.Title="Effect Demo">

    <Grid>
        <StackPanel Margin="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock HorizontalAlignment="Center"
                       Text="Effect Demo"
                       FontSize="20"
                       FontWeight="Bold" />
            <TextBlock Margin="0,8,0,0"
                       HorizontalAlignment="Center">
                <Run Text="Played: " />
                <Run Text="{Binding LastEffectKind, Mode=OneWay}"
                     FontWeight="Bold" />
            </TextBlock>
        </StackPanel>
        <Button Width="100"
                Margin="10"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Command="{Binding Back}"
                Content="Back" />
    </Grid>

</UserControl>
