<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:s="http://smart/windows"
             xmlns:views="clr-namespace:Example.WindowsApp.Views"
             xmlns:animation="clr-namespace:Example.WindowsApp.Modules.Animation"
             mc:Ignorable="d"
             x:Class="Example.WindowsApp.Modules.Animation.AnimationMenuView"
             s:DataContextResolver.Type="{x:Type animation:AnimationMenuViewModel}"
             d:DataContext="{d:DesignInstance Type={x:Type animation:AnimationMenuViewModel}}"
             d:DesignWidth="480"
             d:DesignHeight="320"
             views:ShellProperty.Title="Animation Menu">

    <StackPanel Margin="10" Orientation="Vertical">
        <TextBlock Text="Choose Animation" FontWeight="Bold" Margin="0,0,0,8"/>
        <Button Width="140" Margin="0,4"
                HorizontalAlignment="Left"
                Command="{Binding Navigate}"
                CommandParameter="Forward"
                Content="Forward (Slide Right)" />
        <Button Width="140" Margin="0,4"
                HorizontalAlignment="Left"
                Command="{Binding Navigate}"
                CommandParameter="Back"
                Content="Back (Slide Left)" />
        <Button Width="140" Margin="0,4"
                HorizontalAlignment="Left"
                Command="{Binding Navigate}"
                CommandParameter="Push"
                Content="Push (Slide Up)" />
        <Button Width="140" Margin="0,4"
                HorizontalAlignment="Left"
                Command="{Binding Navigate}"
                CommandParameter="Pop"
                Content="Pop (Slide Down)" />
        <Button Width="140" Margin="0,4"
                HorizontalAlignment="Left"
                Command="{Binding Navigate}"
                CommandParameter="Fade"
                Content="Fade" />
        <Button Width="140" Margin="0,4"
                HorizontalAlignment="Left"
                Command="{Binding Navigate}"
                CommandParameter=""
                Content="No Animation" />
    </StackPanel>

</UserControl>
